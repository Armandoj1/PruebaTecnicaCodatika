<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — BookRadar</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <style>
            body {
                background-color: #f8f9fa;
                font-family: 'Segoe UI', sans-serif;
            }
            .navbar-brand {
                font-weight: 700;
                font-size: 1.4rem;
                letter-spacing: -0.5px;
            }
            .navbar-brand span {
                color: #0d6efd;
            }
            .nav-link {
                font-weight: 500;
            }
            .main-container {
                min-height: calc(100vh - 120px);
                padding: 2.5rem 0;
            }
            footer {
                background-color: #212529;
                color: #adb5bd;
                padding: 1.2rem 0;
                font-size: 0.85rem;
            }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
        <div class="container">
            <a class="navbar-brand" asp-controller="Books" asp-action="Index">
                <i class="bi bi-book-half me-1"></i>Book<span>Radar</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto gap-2">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Books" asp-action="Index">
                            <i class="bi bi-search me-1"></i>Buscar
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Books" asp-action="History">
                            <i class="bi bi-clock-history me-1"></i>Historial
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="main-container">
        <div class="container">
            @RenderBody()
        </div>
    </div>

    <footer>
        <div class="container text-center">
            &copy; 2026 BookRadar — Datos provistos por
            <a href="https://openlibrary.org" target="_blank" class="text-info text-decoration-none">Open Library</a>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>